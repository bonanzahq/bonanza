# ABOUTME: Template for production environment variables.
# ABOUTME: Copy to .env and fill in all values before starting the stack.
#
# Variables marked [required] are needed for correct production operation; some are validated at startup.
# Passwords are URL-encoded automatically; special characters are safe to use.

# -- GitHub Access --
# Read-only PAT for downloading deployment files via deploy.sh
GITHUB_TOKEN=

# -- Application --
# [required] Public hostname for the application
APP_HOST=
# [required] Public port (used in email links)
APP_PORT=443
# Protocol for email links: https or http
APP_PROTOCOL=https

# -- Caddy Reverse Proxy --
# Set to a domain name (e.g. "example.com") for automatic HTTPS via Let's Encrypt
# Set to ":443" for plain HTTP on port 443 (e.g. during testing)
# [required]
CADDY_ADDRESS=

# -- Database --
# [required] Password for the PostgreSQL container
POSTGRES_PASSWORD=

# -- Elasticsearch --
# [required] Password for Elasticsearch
ELASTIC_PASSWORD=

# -- Rails Secrets --
# [required] Generate with: openssl rand -hex 64
SECRET_KEY_BASE=
# Only needed if using Rails encrypted credentials (not currently used)
# RAILS_MASTER_KEY=

# -- Email/SMTP --
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAILER_FROM=

# -- Admin Bootstrap (first deploy only) --
# [required on first deploy] Creates the initial admin user
# Can be removed from .env after first successful boot
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -- Deployment --
# Docker image tag to pull (e.g. "latest", "main", "v1.0.0")
IMAGE_TAG=latest
