# ABOUTME: Template for production environment variables.
# ABOUTME: Copy to .env and fill in all values before starting the stack.

# -- GitHub Access --
# Read-only PAT for downloading deployment files
GITHUB_TOKEN=

# -- Application --
APP_HOST=
APP_PORT=

# -- Database --
# Used by PostgreSQL container and Rails DATABASE_URL construction
POSTGRES_PASSWORD=

# -- Elasticsearch --
# Passwords are URL-encoded automatically; special characters are safe
ELASTIC_PASSWORD=

# -- Rails Secrets --
SECRET_KEY_BASE=
RAILS_MASTER_KEY=

# -- Email/SMTP --
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
MAILER_FROM=

# -- Admin Bootstrap --
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -- Deployment --
IMAGE_TAG=
