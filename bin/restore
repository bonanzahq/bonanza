#!/usr/bin/env bash
# ABOUTME: Restores the bonanza_redux_production database from a backup file.
# ABOUTME: Prompts for confirmation before overwriting the database.

set -e

# Configuration
DATABASE="bonanza_redux_production"
DB_USER="postgres"

# Check if backup file was provided
if [ $# -eq 0 ]; then
  echo "Error: No backup file specified"
  echo "Usage: $0 <backup-file.sql.gz>"
  exit 1
fi

BACKUP_FILE="$1"

# Validate backup file exists
if [ ! -f "${BACKUP_FILE}" ]; then
  echo "Error: Backup file not found: ${BACKUP_FILE}"
  exit 1
fi

# Display what we're about to do
echo "============================================"
echo "DATABASE RESTORE"
echo "============================================"
echo "Backup file: ${BACKUP_FILE}"
echo "Database: ${DATABASE}"
echo "User: ${DB_USER}"
echo ""
echo "WARNING: This will OVERWRITE the current database!"
echo "All existing data in ${DATABASE} will be LOST."
echo "============================================"
echo ""
read -p "Are you sure you want to proceed? (yes/no): " CONFIRM

if [ "${CONFIRM}" != "yes" ]; then
  echo "Restore cancelled."
  exit 0
fi

echo ""
echo "Starting restore..."

# Gunzip and pipe into psql via docker compose
gunzip -c "${BACKUP_FILE}" | docker compose exec -T db psql -U "${DB_USER}" "${DATABASE}"

echo ""
echo "✓ Database restored successfully from ${BACKUP_FILE}"
