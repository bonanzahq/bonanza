{
  "name": "app",
  "version": "2.0.0-beta.1",
  "private": true,
  "dependencies": {
    "@hotwired/stimulus": "3.0.1",
    "@hotwired/turbo-rails": "8.0.23",
    "@popperjs/core": "2.11.2",
    "@tarekraafat/autocomplete.js": "10.2.6",
    "@yaireo/tagify": "4.16.4",
    "dayjs": "1.11.6",
    "esbuild": "0.27.3",
    "hyperform": "0.12.1",
    "pikaday": "1.8.2",
    "purgecss": "4.1.3",
    "sass": "1.48.0",
    "timeago.js": "4.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --outdir=app/assets/builds",
    "build:css": "sass ./app/assets/stylesheets/application.sass.scss ./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "watch": "esbuild app/javascript/*.* --bundle --sourcemap --outdir=app/assets/builds --watch=forever",
    "watch:css": "sass ./app/assets/stylesheets/application.sass.scss ./app/assets/builds/application.css --no-source-map --load-path=node_modules --watch"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "semantic-release": "25.0.3"
  }
}
