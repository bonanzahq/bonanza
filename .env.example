# === Development ===
# Copy this file to .env and adjust as needed.
# Development defaults work with docker-compose.override.yml without changes.

# === Production ===
# These variables MUST be set for production deployments.
# Run with: docker compose -f docker-compose.yml up

# POSTGRES_PASSWORD=your_secure_password
# ELASTIC_PASSWORD=your_elastic_password
# APP_HOST=bonanza.example.com
# APP_PORT=443
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAILER_FROM=
# RAILS_MASTER_KEY=your_master_key
# SECRET_KEY_BASE=your_secret_key_base

# === Shared (optional overrides) ===

# Puma Web Server
# RAILS_MAX_THREADS=5
# RAILS_MIN_THREADS=5
# PORT=3000

# Workers (production with multiple workers)
# WEB_CONCURRENCY=2
