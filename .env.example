# Rails Environment
RAILS_ENV=development

# Database Configuration
# For development with Docker, use DATABASE_URL instead of individual settings
DATABASE_URL=postgresql://postgres:password@db:5432/bonanza_redux_development
# For production, set password separately:
# BONANZA_REDUX_DATABASE_PASSWORD=your_secure_password

# Elasticsearch Configuration
# Development (Docker):
ELASTICSEARCH_URL=http://elasticsearch:9200
# Production (with auth):
# ELASTICSEARCH_URL=https://elastic:your_password@elasticsearch:9200

# Rails Master Key (for decrypting credentials)
# Generate with: rails credentials:edit
# RAILS_MASTER_KEY=your_master_key_here

# Puma Web Server
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=5
PORT=3000
PIDFILE=tmp/pids/server.pid

# Workers (uncomment for production with multiple workers)
# WEB_CONCURRENCY=2

# Email Configuration (Development with Mailpit)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_DOMAIN=localhost
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Email Configuration (Production - example with real SMTP)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_DOMAIN=yourdomain.com
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS_AUTO=true

# Production Settings
# RAILS_SERVE_STATIC_FILES=true
# RAILS_LOG_TO_STDOUT=true

# Redis (for Action Cable, currently not used)
# REDIS_URL=redis://localhost:6379/1

# Application URL
# Used for generating URLs in emails and other places
APP_HOST=localhost
APP_PORT=3000
APP_PROTOCOL=http
