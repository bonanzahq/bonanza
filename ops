{"author":{"id":"cff9ab1d2ee9741039b2a60d90cca378a5320ba753398f6f3df8d03abcebee1b"},"ops":[{"type":1,"timestamp":1771326310,"nonce":"SU+Z6BfBXV4S8uSggSMaq7daTmI=","title":"Verwaltung link hidden from members due to wrong permission check","message":"The Verwaltung link in the user dropdown menu (app/views/shared/_user_menu.html.erb line 9) checks 'can? :manage, current_user.current_department'. Members only have 'can :update, Department', not 'can :manage', so they never see the link.\n\nThis means members cannot reach the Verwaltung page where 'Artikel anlegen' and other management links live, even though ability.rb grants them 'can :manage, ParentItem' for their department.\n\nFix: change the check to 'can? :update, current_user.current_department'.\n\nNote: the existing navigation test (test/integration/navigation_test.rb) asserts the broken behavior ('member does not see Verwaltung link') and needs to be updated as part of the fix.","files":null}]}