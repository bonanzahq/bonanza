<header class="row">
    <div class="col-2">
    </div>
    <div class="col-7 bnz-tab-navigation d-flex align-items-stretch pt-3">
        <h4>Ausleihe</h4>
    </div>
    <div class="col-3 d-flex align-items-center">
        <%= render 'shared/user_menu' %>
    </div>
</header>

<div class="row">
    <div class="col-2 pt-3 d-flex justify-content-end align-items-start">
        <% if user_signed_in? %>
            <%= link_to 'Zurück', lending_path, class: 'link-back link-dark' %>
        <% end %>
    </div>
    <div class="col-7">
        <div class="p-3 bg-light mb-3 rounded">
            
            <h3>
              <%= @lending.line_items.count %> Artikel ausgeliehen
            </h3>
                
            <% @lending.line_items.each_with_index do |line_item, line_item_index| %>
                <% item = Item.find_by(id: line_item.item_id) %>
                <div class="bnz-card<%= ' border-danger' if item.nil? %>">
                    <div class="header">
                        <% if item %>
                        <div class="left fw-bold">
                            <%= item.parent_item.name %>
                        </div>
                        <div class="right">
                            <% if item.storage_location.present? %>
                                <div class="storage-location"><%= item.storage_location %></div>
                            <% end %>

                            
                            <% if item.uid.present? %>
                                <div class="identifier <%= item.condition %>" title="<%= t(item.condition, :scope => 'condition') %>">
                                    <%= item.uid %>
                                </div>
                            <% else %>
                                <%= line_item.quantity %>
                                x
                            <% end %>
                        </div> 
                        <% else %>
                        <div class="left fw-bold text-danger">
                            Artikel nicht mehr vorhanden (ID: <%= line_item.item_id %>)
                        </div>
                        <div class="right">
                            <%= line_item.quantity %> x
                        </div>
                        <% end %>
                    </div>

                    <% if item&.parent_item&.accessories&.any? %>
                        <div class="body">
                            <% item.parent_item.accessories.each do |accessory| %>
                                <div class="item">
                                    <div class="left"><%= accessory.name %></div>
                                    <div class="right">
                                        <div class="form-check-inline me-0">
                                            <input class="form-check-input" type="checkbox" disabled value="">
                                        </div>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    <% end %>

                    <% if item&.parent_item&.links&.any? %>
                        <div class="body">
                            <% item.parent_item.links.each do |link| %>
                                <div class="item">
                                    <div class="left">
                                        <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer">
                                            <%= link.title.present? ? link.title : link.url %>
                                        </a>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    <% end %>

                </div>
            <% end %>

            <hr class="divider">

            <div class="<%= @lending.note.present? ? "mb-2" : "mb-4" %> line justify-content-between">
                <div class="left d-flex align-items-center"><h4 class="mb-0"><%= @lending.borrower.fullname %></h4></div>
                <div class="right" >
                    <p>Rückgabe am <span class="fw-bold"><%= l(@lending.lent_at.to_date + @lending.duration.days, format: "%a. %d.%m.%y") %></span></p>
                </div>
            </div>

            <% if @lending.note.present? %>
            <div class="mb-4">
                <div class="form-label">Anmerkung zur Ausleihe</div>
                <div>
                    <%= @lending.note %>
                </div>
            </div>
            <% end %>
       
            <% if user_signed_in? and can? :manage, @lending and @lending.returned_at.nil? %>
                <% has_orphaned = @lending.line_items.any? { |li| Item.where(id: li.item_id).none? } %>
                <% if has_orphaned %>
                <div class="p-3 bg-warning bg-opacity-10 border border-warning rounded mb-3">
                    <p class="fw-bold mb-2">Diese Ausleihe enthält Artikel, die nicht mehr existieren.</p>
                    <p class="mb-2">Eine normale Rückgabe ist nicht möglich. Mit der Zwangsschließung werden alle Artikel als zurückgegeben markiert.</p>
                    <a href="#" class="btn btn-warning" data-controller="modal" data-action="click->modal#showModal" data-modal-modalID-param="forceCloseModal">Ausleihe zwangsweise schließen</a>
                </div>
                <% end %>
            <% end %>

            <% if user_signed_in? and can? :update, @lending %>
                <div class="actions">
                    <div>
                        <a href="#" class="btn btn-primary" data-controller="modal" data-action="click->modal#showModal" data-modal-modalID-param="editDurationModal">Rückgabedatum ändern</a>
                        <a href="#" class="btn btn-outline-secondary" id="printable_agreement_link">Drucken</a>

                        <iframe style="display:none" id="printable_agreement" src="<%= lending_agreement_path(@lending.id, @lending.token) %>" ></iframe>
                        <script>
                            document.getElementById('printable_agreement_link').addEventListener("click", function(event) {
                                event.preventDefault()
                                var frame = document.getElementById("printable_agreement").contentWindow
                                frame.focus();
                                frame.print();

                                event.target.blur()
                            })
                        </script>
                    </div>
                    <div class="right">
                        <%= button_to "Delete 2", lending_destroy_path, method: :delete, form: { data: { turbo: false } }, class: "btn btn-outline-secondary" %>
                    </div>
                </div>
            <% end %>
        </div>
    </div>
    <div class="col-3">
    </div>

    <div class="modal fade" id="forceCloseModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Ausleihe zwangsweise schließen</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <%= form_with url: force_close_lending_path(@lending), method: :patch, data: { turbo: false } do |form| %>
          <div class="modal-body">
            <p>Alle Artikel werden als zurückgegeben markiert. Diese Aktion kann nicht rückgängig gemacht werden.</p>
            <div class="mb-3">
              <%= form.label :reason, "Grund", class: "form-label" %>
              <%= form.text_area :reason, class: "form-control", rows: 3, required: true, placeholder: "Warum wird diese Ausleihe zwangsweise geschlossen?" %>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
            <%= form.submit "Zwangsweise schließen", class: "btn btn-warning" %>
          </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="modal fade" id="editDurationModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Rückgabedatum ändern</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <%= form_with model: @lending, url: change_lending_duration_path(@lending), data: {turbo: false} do |form| %>
          <div class="modal-body">
            <div class="set-duration" data-controller="datepicker" data-datepicker-startdate-value="<%= @lending.lent_at.to_date %>">
                <p>Neue Rückgabe am</p>
                <%= form.hidden_field :duration, class: "form-control days", required: true, data: { "datepicker-target": "output"} %>
                <input class="form-control date" type="text" name="" data-datepicker-target="input">
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
            <%= form.submit "Änderung speichern", class: "btn btn-primary" %>
          </div>
          <% end %>
        </div>
      </div>
    </div>
</div>