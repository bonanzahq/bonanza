<%# ABOUTME: Persistent banner warning users with weak passwords to change them. %>
<%# ABOUTME: Rendered on every page when session[:weak_password] is set. %>
<div class="alert alert-warning alert-dismissible fade show mb-0 rounded-0 py-2 px-3" role="alert">
  <%= t("weak_password_warning") %>
  <%= link_to t("weak_password_change_link"), edit_user_path(current_user), class: "alert-link" %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
