<%# ABOUTME: Management view for a single department. %>
<%# ABOUTME: Shown to admins and leaders; displays department details with edit actions. %>

<header class="row">
    <div class="col-2">
    </div>
    <div class="col-7 bnz-tab-navigation d-flex align-items-stretch pt-3">
        <h4>Werkstatt</h4>
    </div>
    <div class="col-3 d-flex align-items-center">
        <%= render 'shared/user_menu' %>
    </div>
</header>

<div class="row">
    <div class="col-2 pt-3 d-flex justify-content-end align-items-start">
        <%= link_to "Werkstätten", departments_path, class: "link-back link-dark" %>
    </div>
    <div class="col-7">
        <div class="p-3 bg-light rounded mb-3 w-100">
            <div class="d-flex justify-content-between align-items-start">
                <h3><%= @department.name %></h3>
                <% if can? :edit, @department %>
                    <%= link_to 'bearbeiten', edit_department_path(@department), class: 'icon edit' %>
                <% end %>
            </div>

            <div class="bnz-card">
                <div class="header pb-0">
                    <h4>Details</h4>
                </div>
                <div class="body">
                    <div class="line">
                        <strong class="label">Raum</strong> <%= @department.room %>
                    </div>

                    <% unless @department.time.blank? %>
                        <div class="line">
                            <strong class="label">Öffnungszeiten</strong> <%= @department.time %>
                        </div>
                    <% end %>

                    <% unless @department.note.blank? %>
                        <div class="line desc" data-controller="readmore">
                            <strong class="label">Beschreibung</strong>
                            <%= render_markdown(@department.note) %>
                        </div>
                    <% end %>

                    <div class="line">
                        <strong class="label">Standardausleihdauer</strong> <%= @department.default_lending_duration %> Tage
                    </div>

                    <div class="line">
                        <strong class="label">Status</strong>
                        <% if @department.staffed %>
                            <span class="text-success">Geöffnet</span>
                            <% if @department.staffed_at %>
                                <span class="text-muted small">(seit <%= l(@department.staffed_at.to_date, format: "%d.%m.%Y") %>)</span>
                            <% end %>
                        <% else %>
                            <span class="text-danger">Geschlossen</span>
                        <% end %>
                    </div>

                    <% if @department.hidden %>
                        <div class="line">
                            <span class="text-muted">Versteckt</span>
                        </div>
                    <% end %>
                </div>
            </div>

            <% staff = @department.department_memberships.includes(:user).where.not(role: [0, 3, 99]).where(user: { invitation_created_at: nil }).or(@department.department_memberships.includes(:user).where.not(role: [0, 3, 99]).where.not(user: { invitation_created_at: nil }).where.not(user: { invitation_accepted_at: nil })) %>
            <% if staff.any? %>
                <div class="bnz-card mt-3">
                    <div class="header pb-0">
                        <h4>Verleihende</h4>
                    </div>
                    <div class="body">
                        <% staff.each do |membership| %>
                            <div class="line">
                                <%= membership.user.fullname %>
                                <span class="text-muted small">(<%= membership.role %>)</span>
                            </div>
                        <% end %>
                    </div>
                </div>
            <% end %>

            <div class="mt-3 d-flex gap-2">
                <% if can? :staff, @department %>
                    <% if @department.staffed %>
                        <%= link_to "Werkstatt vorübergehend schließen", unstaff_department_path(@department), class: 'btn btn-outline-secondary btn-sm', data: { turbo_method: :patch } %>
                    <% else %>
                        <%= link_to "Werkstatt wieder öffnen", staff_department_path(@department), class: 'btn btn-outline-secondary btn-sm', data: { turbo_method: :patch } %>
                    <% end %>
                <% end %>
            </div>
        </div>
    </div>
    <div class="col-3">
    </div>
</div>
