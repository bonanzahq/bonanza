<header class="row">
    <div class="col-2">
    </div>
    <div class="col-7 bnz-tab-navigation d-flex align-items-stretch pt-3">
        <h3>Für die Ausleihe registrieren</h3>
    </div>
    <div class="col-3 d-flex align-items-center">
        <%= render 'shared/user_menu' %>
    </div>
</header>

<div class="row">
    <div class="col-2 pt-3 d-flex justify-content-end align-items-start">
    </div>
    <div class="col-7">
        <% if @tos.present? %>
          <div class="bg-light p-3 rounded mb-3 pb-1">
            <h4>Ausleihbedingungen</h4>
            <p class="small text-muted">Stand <%= l(@tos.created_at, :format => "%d.%m.%Y") %></p>
            <div class="tos-content" tabindex="0" role="region" aria-label="Ausleihbedingungen">
              <%= render_markdown(@tos.content) %>
            </div>
          </div>
        <% end %>

        <div class="p-3 rounded bg-light mb-3">
          
          <%= render "self_register_form", borrower: @borrower %>
          
        </div>
    </div>
    <div class="col-3">
    </div>
</div>

<div class="row">
    <div class="col-2">
    </div>
    <div class="col-7">
        <%= render "shared/footer" %>
    </div>
    <div class="col-3">
    </div>
</div>
