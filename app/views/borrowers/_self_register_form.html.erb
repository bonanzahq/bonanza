<%= form_with(model: borrower, url: borrower_self_create_url, data: {turbo: false, controller: 'form-validation'}) do |form| %>
  <% if borrower.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(borrower.errors.count, "error") %> prohibited this borrower from being saved:</h2>
      <ul>
        <% borrower.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<div class="row">
  <div class="col-8">
    <div class="mb-2 with-message">
      <%= form.label :firstname, "Vorname", class: "form-label", data: { "msg": "Beim Ausleihen werden Deine Daten überprüft. Also bitte keine Donald Ducks, Supermans und der gleichen."} %>
      <%= form.text_field :firstname, :autocomplete => 'off', class: "form-control", :required => true, data: { "value-missing": "Bitte Vorname angeben" } %>
    </div>

    <div class="mb-2">
      <%= form.label :lastname, "Nachname", class: "form-label" %>
      <%= form.text_field :lastname, :autocomplete => 'off', class: "form-control", :required => true, data: { "value-missing": "Bitte Nachname angeben"} %>
    </div>

    <div class="mb-2 with-message">
      <%= form.label :email, "E-Mail", class: "form-label", data: { "msg": "An diese E-Mail-Adresse bekommst Du Ausleihbestätigungen und Erinnerungen."} %>
      <%= form.email_field :email, :autocomplete => 'off', class: "form-control", :required => true, data: { "value-missing": "Bitte E-Mail angeben", "type-mismatch": "Bitte eine valide E-Mail-Adresse angeben"} %>
    </div>

    <div class="mb-2">
      <%= form.label :phone, "Telefon", class: "form-label" %>
      <%= form.text_field :phone, :autocomplete => 'off', class: "form-control", :required => true, data: { "value-missing": "Bitte Telefonnummer angeben"} %>
    </div>

    <div class="<% if borrower.borrower_type == "employee" %>mb-4<% else %>mb-2<% end %> with-message">
      <%= form.label :borrower_type, "Art", class: "form-label", data: { "msg": "Nur immatrikulierte Studierende oder Mitarbeitende der FH können Bonanza nutzen."} %>
      <%= form.select :borrower_type, options_for_select(Borrower.borrower_types.map {|key, value| 
        unless key == "deleted"
          [t(key, :scope => "type"), Borrower.borrower_types.key(value)]
        else
          nil 
      end
      }.compact, borrower.borrower_type), {}, {class: "form-select", data: { "controller": "student-id-input", "action": "student-id-input#toggleInput"}}%>
    </div>

    <div class="mb-2 student-id <% if borrower.borrower_type == "employee" %>d-none<% end %>">
      <%= form.label :student_id, "Matrikelnummer", class: "form-label" %>
      <%= form.text_field :student_id, :autocomplete => 'off', class: "form-control" %>
    </div>

    <div class="mb-4 form-check check-input-container">
      <%= form.check_box :tos_accepted, :autocomplete => 'off', required: true, class: "form-check-input", data: { "value-missing": "Du musst die Ausleihbedingungen akzeptieren, um fortfahren zu können"} %>
      <%= form.label :tos_accepted, class: "form-check-label" do %>
        Ich akzeptieren die <%= link_to "Ausleihbedingungen", ausleihbedingungen_path %>.
      <% end %>
    </div>

    <div class="actions">
      <%= link_to "Abbrechen", root_path, class: "btn btn-outline-secondary" %>
      <%= form.submit "Registrieren", class: "btn btn-primary" %>
    </div>
  </div>
  <div class="col-4">
  </div>
</div>
<% end %>
