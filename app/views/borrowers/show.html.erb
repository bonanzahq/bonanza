<header class="row">
    <div class="col-2">
    </div>
    <div class="col-7 bnz-tab-navigation d-flex align-items-stretch pt-3">
        <h4>Ausleihende Person</h4>
    </div>
    <div class="col-3 d-flex align-items-center">
        <%= render 'shared/user_menu' %>
    </div>
</header>

<div class="row">
    <div class="col-2 pt-3 d-flex justify-content-end align-items-start">
        <%- if current_page?(borrower_path) %>
            <% if can? :manage, current_user.current_department %>
                <%= link_to "Verwaltung", borrowers_path, class: "link-back link-dark" %>
            <% else %>
                <%= link_to "Ausleihe", lending_path, class: "link-back link-dark" %>
            <% end %>
        <%- elsif current_page?( checkout_borrower_path ) %>
            <%= link_to "Zurück", checkout_state_path('borrower'), class: "link-back link-dark" %>
        <%- else %>
            <%= link_to "Zurück", root_path, class: "link-back link-dark" %>
        <%- end %>
    </div>
    <div class="col-7">
        <div class="p-3 bg-light rounded mb-3 w-100 borrowers">
          <%= render partial: @borrower %>
        </div>
    </div>
    <div class="col-3">
    </div>
</div>
