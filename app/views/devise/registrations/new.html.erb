<div class="row justify-content-center">
  <div class="col-6 pt-3">
    <h3>Registrieren</h3>
    <div class="bg-light p-3 rounded mb-3 position-relative">
      <a href="/" class="link-back link-dark">Zur Startseite</a>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        
        <div class="mb-2">
          <%= f.label :email, "E-Mail-Adresse", class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        </div>

        <div class="mb-2">
          <%= f.label :password, "Passwort", class: "form-label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          <% if @minimum_password_length %>
            <small class="form-text text-muted">(mindestens <%= @minimum_password_length %> Zeichen)</small>
          <% end %>
        </div>

        <div class="mb-2">
          <%= f.label :password_confirmation, "Passwort wiederholen", class: "form-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="actions d-flex">
          <%= f.submit "Registrieren", class: "btn btn-primary flex-fill" %>
        </div>
      <% end %>
      
      <div class="mt-2">
        <%= link_to "Bereits registriert? Anmelden", new_user_session_path, class: "small" %>
      </div>
    </div>
  </div>
</div>
