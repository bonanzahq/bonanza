<header class="row">
    <div class="col-2">
    </div>
    <div class="col-7 bnz-tab-navigation d-flex align-items-stretch pt-3">
        <h3>Profil bearbeiten</h3>
    </div>
    <div class="col-3 d-flex align-items-center">
        <%= render 'shared/user_menu' %>
    </div>
</header>

<div class="row">
    <div class="col-2 pt-3 d-flex justify-content-end align-items-start">
    </div>
    <div class="col-7">
        <div class="p-3 bg-light mb-3 rounded">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }, data: { turbo: false }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="mb-2">
                <%= f.label :email, "E-Mail-Adresse", class: "form-label" %>
                <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
            </div>

            <div class="mb-2">
                <%= f.label :password, "Neues Passwort (leer lassen, wenn nicht ändern)", class: "form-label" %>
                <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
                <% if @minimum_password_length %>
                  <small class="form-text text-muted"><%= @minimum_password_length %> Zeichen Minimum</small>
                <% end %>
            </div>

            <div class="mb-2">
                <%= f.label :password_confirmation, "Passwort wiederholen", class: "form-label" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
            </div>

            <div class="mb-2">
                <%= f.label :current_password, "Aktuelles Passwort", class: "form-label" %>
                <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
            </div>

            <div class="actions">
                <%= f.submit "Aktualisieren", class: "btn btn-primary" %>
            </div>
          <% end %>
          
          <hr class="my-4">
          
          <h4>Konto löschen</h4>
          <p class="text-muted">Diese Aktion kann nicht rückgängig gemacht werden.</p>
          <%= button_to "Konto löschen", registration_path(resource_name), method: :delete, class: "btn btn-danger", form: { data: { turbo: false } }, data: { turbo_confirm: "Bist du sicher?" } %>
        </div>
    </div>
    <div class="col-3">
    </div>
</div>
